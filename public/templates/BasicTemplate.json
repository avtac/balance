{
  "name": "Test",
  "size": "Letter",
  "style": "body {padding: .25in} table, th, td {border-collapse: collapse;border: 1px solid black;}h1 {color: red}",
  "body": [
    {
      "type": "h1",
      "content": "Weight and Balance",
      "style": {}
    },
    {
      "type": "div",
      "style": {
        "width": "100%",
        "display": "grid",
        "gridTemplateColumns": "auto 1fr"
      },
      "content": [
        {
          "type": "div",
          "content": [
            {
              "type": "div",
              "style": {
                "display": "grid",
                "gridTemplateColumns": "7rem auto"
              },
              "content": [
                {
                  "type": "p",
                  "content": "Created By: "
                },
                {
                  "type": "p",
                  "action": "manual",
                  "content": "Name"
                }
              ]
            },
            {
              "type": "div",
              "style": {
                "display": "grid",
                "gridTemplateColumns": "7rem auto"
              },
              "content": [
                {
                  "type": "p",
                  "content": "Pilot: "
                },
                {
                  "type": "p",
                  "action": "manual",
                  "content": "Pilot"
                }
              ]
            },
            {
              "type": "div",
              "style": {
                "display": "grid",
                "gridTemplateColumns": "7rem auto"
              },
              "content": [
                {
                  "type": "p",
                  "content": "Date Created: "
                },
                {
                  "type": "p",
                  "action": "function",
                  "content": "() => global.date('MM/DD/YYYY')"
                }
              ]
            },
            {
              "type": "div",
              "style": {
                "display": "grid",
                "gridTemplateColumns": "7rem auto"
              },
              "content": [
                {
                  "type": "p",
                  "content": "Tail Number:"
                },
                {
                  "type": "p",
                  "action": "function",
                  "content": "() => global.aircraftTailNumber"
                },
                {
                  "type": "p",
                  "content": "Aircraft Type:"
                },
                {
                  "type": "p",
                  "action": "function",
                  "content": "() => global.aircraftType"
                }
              ]
            },
            {
              "type": "table",
              "id": "mainTable",
              "className": "basicTable",
              "content": [
                {
                  "type": "thead",
                  "content": [
                    {
                      "type": "tr",
                      "content": [
                        {
                          "type": "th",
                          "content": " "
                        },
                        {
                          "type": "th",
                          "action": "function",
                          "content": "() => 'Weight ' + global.units.weightUnits"
                        },
                        {
                          "type": "th",
                          "action": "function",
                          "content": "() => 'Moment ' + global.units.weightUnits + global.units.lengthUnits"
                        },
                        {
                          "type": "th",
                          "action": "function",
                          "content": "() => 'Arm ' + global.units.lengthUnits"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "tbody",
                  "content": [
                    {
                      "type": "tr",
                      "style": {
                        "fontWeight": "bold"
                      },
                      "content": [
                        {
                          "type": "td",
                          "content": "Empty Aircraft"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.emptyWeight"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.emptyWeight * global.emptyArm"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.emptyArm"
                        }
                      ]
                    },
                    {
                      "type": "tr",
                      "content": [
                        {
                          "type": "td",
                          "content": "Crew Weight"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.crewWeight"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.crewWeight * global.crewArm"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.crewArm"
                        }
                      ]
                    },
                    {
                      "type": "tr",
                      "content": [
                        {
                          "type": "td",
                          "content": "Empty Aircraft"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.crewCargoWeight"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.crewCargoWeight * global.crewCargoArm"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.crewCargoArm"
                        }
                      ]
                    },
                    {
                      "type": "tr",
                      "content": [
                        {
                          "type": "td",
                          "content": "Equipment"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.equipmentWeight"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.equipmentWeight * global.equipmentArm"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.equipmentArm"
                        }
                      ]
                    },
                    {
                      "type": "tr",
                      "style": {
                        "fontWeight": "bold"
                      },
                      "content": [
                        {
                          "type": "td",
                          "content": "Ops Config"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.opsWeight"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.opsWeight * global.opsArm"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.opsArm"
                        }
                      ]
                    },
                    {
                      "type": "tr",
                      "content": [
                        {
                          "type": "td",
                          "content": "Passengers"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.passengerWeight"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.passengerWeight * global.passengerArm"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.passengerArm"
                        }
                      ]
                    },
                    {
                      "type": "tr",
                      "content": [
                        {
                          "type": "td",
                          "content": "Cargo"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.cargoWeight"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.cargoWeight * global.cargoArm"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.getMac(global.cargoArm)"
                        }
                      ]
                    },
                    {
                      "type": "tr",
                      "content": [
                        {
                          "type": "td",
                          "content": "Fuel"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.totalFuelWeight"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.roundNumber(global.totalFuelWeight * global.totalFuelArm, 1)"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.totalFuelArm"
                        }
                      ]
                    },
                    {
                      "type": "tr",
                      "style": {
                        "fontWeight": "bold"
                      },
                      "content": [
                        {
                          "type": "td",
                          "content": "Takeoff"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.takeoffWeight"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.takeoffWeight * global.takeoffArm"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.takeoffArm"
                        }
                      ]
                    },
                    {
                      "type": "tr",
                      "content": [
                        {
                          "type": "td",
                          "content": "Trip Fuel"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.fuelBurnWeight"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => '___'"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => '___'"
                        }
                      ]
                    },
                    {
                      "type": "tr",
                      "style": {
                        "fontWeight": "bold"
                      },
                      "content": [
                        {
                          "type": "td",
                          "content": "Landing"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.landingWeight"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.landingWeight * global.landingArm"
                        },
                        {
                          "type": "td",
                          "action": "function",
                          "content": "() => global.landingArm"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "div",
          "content": [
            {
              "type": "div",
              "action": "function",
              "content": "() => global.graph({background: false})"
            },
            {
              "type": "div",
              "action": "function",
              "content": "() => global.diagram"
            }
          ]
        }
      ]
    }
  ]
}
